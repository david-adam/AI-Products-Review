# ScraperAPI Configuration
# Get your API key from: https://scraperapi.com

# Your ScraperAPI key
SCRAPERAPI_API_KEY=your_api_key_here

# Optional: Amazon affiliate tag for affiliate links
AMAZON_AFFILIATE_TAG=your_affiliate_tag-20

# Optional: Database path
DB_PATH=products.db

# Optional: Number of products to fetch
PRODUCT_LIMIT=20
